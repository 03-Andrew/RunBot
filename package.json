{
  "name": "runbot",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "npm --prefix lambdas/health run build && npm --prefix lambdas/aiAnalysis run build",
    "start:local": "node scripts/serve-local.js",
    "dev": "npm run build && node scripts/serve-local.js",
    "terraform:init": "terraform -chdir=infrastructure init",
    "terraform:apply": "terraform -chdir=infrastructure apply",
    "test:strava": "node scripts/test-strava.js"
  }
}
